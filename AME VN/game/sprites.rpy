#Hina Sprites
layeredimage hina1:
    #base
    always "hina1_base"

    #eyes
    group eyes auto:
        attribute neutral default:
            "hina1_eyes_neutral"
        
    #mouth
    group mouth auto:
        attribute open default:
            "hina1_mouth_open"

    #armL
    group arml auto:
        attribute fistl default:
            "hina1_arml_fistl"

    #armR
    group armr:
        attribute downr default:
            "hina1_armr_downr"

    #extra
    attribute angryx:
        "hina1_extra_angry" 
    attribute blushx:
        "hina1_extra_blush"
    attribute drops:
        "hina1_extra_drops"
    attribute sparklex:
        "hina1_extra_sparkle"
    attribute sweatx:
        "hina1_extra_sweat"

