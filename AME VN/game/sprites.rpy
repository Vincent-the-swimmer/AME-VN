layeredimage hina:
    #base
    always "hina1"

    #eyes
    group eyes:
        attribute neutral default:
            "hina1_eyes_neutral"
        attribute sad:
            "hina1_eyes_sad"
        attribute wink:
            "hina1_eyes_wink"
        attribute worry:
            "hina1_eyes_worry"

    #mouth
    group mouth:
        attribute open default:
            "hina1_mouth_open"
        attribute grit:
            "hina1_mouth_grit"
        attribute smile:
            "hina1_mouth_smile"
        attribute smirk:
            "hina1_mouth_smirk"
        attribute tongue:
            "hina1_mouth_tongue"

    #armL
    group armL:
        attribute fist default:
            "hina1_arml_fist"
        attribute peace:
            "hina1_arml_peace"
        attribute point:
            "hina1_arml_point"
    #armR
    group armR:
        attribute down default:
            "hina1_armr_down"

    #extra
    attribute angry:
        "hina1_extra_angry" 
    attribute blush:
        "hina1_extra_blush"
    attribute drops:
        "hina1_extra_drops"
    attribute sparkle:
        "hina1_extra_sparkle"
    attribute sweat:
        "hina1_extra_sweat"

layeredimage cole1:
    #base
    always "cole12"

    #flame
    group flame auto:
        attribute redcalm default

    # mouth
    group mouth auto:
        attribute open default

    # armL
    group arml:
        attribute pocket default:
                "cole1_arml_pocket"
        attribute claw:
            "cole1_arml_claw"

    # armR:
    group armr:
        attribute grip default:
            "cole1_armr_grip"
        attribute flame:
            "cole1_armr_flame"
        attribute tie:
            "cole1_armr_tie"
        attribute claw:
            "cole1_armr_claw" 
    
    # extra
    attribute sweat:
        "cole1_extra_sweat"
    attribute angry:
        "cole1_extra_angry"
    attribute sparkle:  
        "cole1_extra_sparkle"   
        